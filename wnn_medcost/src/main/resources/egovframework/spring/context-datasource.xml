<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:jdbc="http://www.springframework.org/schema/jdbc"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-4.0.xsd
        http://www.springframework.org/schema/jdbc  http://www.springframework.org/schema/jdbc/spring-jdbc-4.0.xsd">

	<!-- ============================================================== -->
	<!-- Spring Profile 기반 DataSource 분리                              -->
	<!-- local : 로컬 개발환경 (Eclipse/STS에서 실행)                      -->
	<!-- prod  : 서버 운영환경 (서버 Tomcat에서 실행)                       -->
	<!-- 배포 시 파일 수정 불필요! JVM 옵션으로 자동 전환                     -->
	<!-- ============================================================== -->

	<!-- ==================== 로컬 개발환경 ==================== -->
	<beans profile="local">
	    <bean id="dataSource" class="org.apache.commons.dbcp2.BasicDataSource" destroy-method="close">
	        <property name="driverClassName" value="com.mysql.cj.jdbc.Driver"/>
	        <property name="url" value="jdbc:mysql://114.108.153.178:3306/WNN?allowMultiQueries=true&amp;rewriteBatchedStatements=true&amp;useServerPrepStmts=false" />
	        <property name="username" value="winner"/>
	        <property name="password" value="winnerdb_20@%"/>

	        <!-- ===== 커넥션 검증/정리 (오염·끊긴 커넥션 재사용 차단) ===== -->
	        <!-- 빌릴 때 검사: 오염/끊긴 커넥션이면 폐기 후 새 커넥션 발급 (연속 업로드 90000 차단 핵심) -->
	        <property name="testOnBorrow" value="true"/>
	        <property name="validationQuery" value="SELECT 1"/>
	        <property name="validationQueryTimeout" value="3"/>
	        <!-- 유휴 커넥션도 주기적으로 검사·정리 -->
	        <property name="testWhileIdle" value="true"/>
	        <property name="timeBetweenEvictionRunsMillis" value="30000"/>
	        <property name="minEvictableIdleTimeMillis" value="60000"/>
	        <!-- 풀 크기: 기본(maxTotal 8)은 대량 업로드+다중 사용자에 부족 -->
	        <property name="maxTotal" value="20"/>
	        <property name="maxIdle" value="10"/>
	        <property name="minIdle" value="2"/>
	        <!-- 풀 고갈 시 무한 대기 대신 빠르게 실패 (10초) -->
	        <property name="maxWaitMillis" value="10000"/>
	        <!-- 반납 누락(누수) 커넥션 회수 — 대형 샘파일 업로드(수만 줄)가 300초를 넘길 수 있어 900초로 상향 (2026-07-09) -->
	        <property name="removeAbandonedOnBorrow" value="true"/>
	        <property name="removeAbandonedTimeout" value="900"/>
	    </bean>
	</beans>

	<!-- ==================== 서버 운영환경 ==================== -->
	<beans profile="prod">
	    <bean id="dataSource" class="org.apache.commons.dbcp2.BasicDataSource" destroy-method="close">
	        <property name="driverClassName" value="com.mysql.cj.jdbc.Driver"/>
	        <property name="url" value="jdbc:mysql://localhost:3306/WNN?allowMultiQueries=true&amp;rewriteBatchedStatements=true&amp;useServerPrepStmts=false" />
	        <property name="username" value="winner"/>
	        <property name="password" value="winnerdb_20@%"/>

	        <!-- ===== 커넥션 검증/정리 (오염·끊긴 커넥션 재사용 차단) ===== -->
	        <!-- 빌릴 때 검사: 오염/끊긴 커넥션이면 폐기 후 새 커넥션 발급 (연속 업로드 90000 차단 핵심) -->
	        <property name="testOnBorrow" value="true"/>
	        <property name="validationQuery" value="SELECT 1"/>
	        <property name="validationQueryTimeout" value="3"/>
	        <!-- 유휴 커넥션도 주기적으로 검사·정리 -->
	        <property name="testWhileIdle" value="true"/>
	        <property name="timeBetweenEvictionRunsMillis" value="30000"/>
	        <property name="minEvictableIdleTimeMillis" value="60000"/>
	        <!-- 풀 크기: 기본(maxTotal 8)은 대량 업로드+다중 사용자에 부족 -->
	        <property name="maxTotal" value="20"/>
	        <property name="maxIdle" value="10"/>
	        <property name="minIdle" value="2"/>
	        <!-- 풀 고갈 시 무한 대기 대신 빠르게 실패 (10초) -->
	        <property name="maxWaitMillis" value="10000"/>
	        <!-- 반납 누락(누수) 커넥션 회수 — 대형 샘파일 업로드(수만 줄)가 300초를 넘길 수 있어 900초로 상향 (2026-07-09) -->
	        <property name="removeAbandonedOnBorrow" value="true"/>
	        <property name="removeAbandonedTimeout" value="900"/>
	    </bean>
	</beans>

</beans>
