<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:jdbc="http://www.springframework.org/schema/jdbc"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-4.0.xsd
        http://www.springframework.org/schema/jdbc  http://www.springframework.org/schema/jdbc/spring-jdbc-4.0.xsd">

	<!-- ============================================================== -->
	<!-- Spring Profile 기반 DataSource 분리                              -->
	<!-- local : 로컬 개발환경 (Eclipse/STS에서 실행)                      -->
	<!-- prod  : 서버 운영환경 (서버 Tomcat에서 실행)                       -->
	<!-- 배포 시 파일 수정 불필요! JVM 옵션으로 자동 전환                     -->
	<!-- ============================================================== -->

	<!-- ==================== 로컬 개발환경 ==================== -->
	<beans profile="local">
	    <bean id="dataSource" class="org.apache.commons.dbcp2.BasicDataSource" destroy-method="close">
	        <property name="driverClassName" value="com.mysql.cj.jdbc.Driver"/>
	        <property name="url" value="jdbc:mysql://114.108.153.178:3306/WNN" />
	        <property name="username" value="winner"/>
	        <property name="password" value="winnerdb_20@%"/>
	    </bean>
	</beans>

	<!-- ==================== 서버 운영환경 ==================== -->
	<beans profile="prod">
	    <bean id="dataSource" class="org.apache.commons.dbcp2.BasicDataSource" destroy-method="close">
	        <property name="driverClassName" value="com.mysql.cj.jdbc.Driver"/>
	        <property name="url" value="jdbc:mysql://localhost:3306/WNN" />
	        <property name="username" value="winner"/>
	        <property name="password" value="winnerdb_20@%"/>
	    </bean>
	</beans>

</beans>
